# 1️⃣ Use official Node 22 image (lightweight)
FROM node:22-alpine

# 2️⃣ Set working directory inside container
WORKDIR /app

# 3️⃣ Copy package files first (for caching)
COPY package*.json ./

# 4️⃣ Install dependencies
RUN npm install

# 5️⃣ Copy rest of backend code
COPY . .

# 6️⃣ Expose backend port
EXPOSE 5000

# 7️⃣ Start the backend
CMD ["node", "index.js"]
